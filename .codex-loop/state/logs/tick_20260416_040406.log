 taskHasStatus(task, THREAD_ACTIVE_TASK_STATES)) || null;\n   274\t  return {\n   275\t    teamEnabled: true,\n   276\t    assignedCount: owned.length,\n   277\t    activeTask,\n   278\t  };\n   279\t}\n   280\t\n   281\tfunction readTeamSpace(workspacePath) {\n   282\t  const paths = pathsForWorkspace(workspacePath);\n   283\t  if (!paths.root || !fs.existsSync(paths.root)) {\n   284\t    return {\n   285\t      available: false,\n   286\t      workspace: paths.workspace || undefined,\n   287\t      workspaceLabel: path.basename(paths.workspace || \"\") || undefined,\n   288\t      root: paths.root || undefined,\n   289\t      teamBriefPath: paths.teamBriefPath || undefined,\n   290\t      tasks: [],\n   291\t      agents: [],\n   292\t      recentEvents: [],\n   293\t      summary: {\n   294\t        taskCount: 0,\n   295\t        blockedCount: 0,\n   296\t        runningCount: 0,\n   297\t        assignedCount: 0,\n   298\t        completedCount: 0,\n   299\t        staleCount: 0,\n   300\t        agentCount: 0,\n   301\t      },\n   302\t    };\n   303\t  }\n   304\t  const tasks = readTaskRecords(paths);\n   305\t  const agents = readAgentRecords(paths);\n   306\t  const counts = tasks.reduce((acc, task) => {\n   307\t    const status = taskStatus(task);\n   308\t    acc.taskCount += 1;\n   309\t    if (status === TASK_STATES.BLOCKED) acc.blockedCount += 1;\n   310\t    if (status === TASK_STATES.RUNNING) acc.runningCount += 1;\n   311\t    if (status === TASK_STATES.ASSIGNED) acc.assignedCount += 1;\n   312\t    if (status === TASK_STATES.COMPLETED) acc.completedCount += 1;\n   313\t    if (status === TASK_STATES.STALE) acc.staleCount += 1;\n   314\t    return acc;\n   315\t  }, {\n   460\tasync function claimTaskForThread(panel, threadId) {\n   461\t  const liveThread = resolveLiveThread(panel, threadId);\n   462\t  if (!liveThread) return;\n   463\t  const nextThreadId = liveThread.id;\n   464\t  const workspacePath = promptForWorkspace(panel);\n   465\t  co