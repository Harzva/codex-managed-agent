l\": {\n          \"type\": \"string\",\n          \"default\": \"http://127.0.0.1:8787/\",\n          \"description\": \"Base URL for the running Codex-Managed-Agent web app.\"\n        },\n        \"codexAgent.autoStartServer\": {\n          \"type\": \"boolean\",\n          \"default\": true,\n          \"description\": \"Automatically start the local Codex-Managed-Agent FastAPI service when the panel opens and the server is not reachable.\"\n        },\n        \"codexAgent.pythonPath\": {\n          \"type\": \"string\",\n          \"default\": \"\",\n          \"description\": \"Optional Python executable used to launch the local Codex-Managed-Agent server. Leave empty to auto-detect .venv/bin/python3 or use python3.\"\n        },\n        \"codexAgent.serverRoot\": {\n          \"type\": \"string\",\n          \"default\": \"\",\n          \"description\": \"Optional absolute path to the Codex Manager server root directory that contains the Python package folder `codex_manager/`.\"\n        }\n      }\n    },\n    \"commands\": [\n      {\n        \"command\": \"codexAgent.openPanel\",\n        \"title\": \"Codex-Managed-Agent: Open Dashboard\"\n      },\n      {\n        \"command\": \"codexAgent.openExternal\",\n        \"title\": \"Codex-Managed-Agent: Open in Browser\"\n      },\n      {\n        \"command\": \"codexAgent.showSidebar\",\n        \"title\": \"Codex-Managed-Agent: Show in Sidebar\"\n      },\n      {\n        \"command\": \"codexAgent.showBottomPanel\",\n        \"title\": \"Codex-Managed-Agent: Show in Bottom Panel\"\n      },\n      {\n        \"command\": \"codexAgent.openPanelBeside\",\n        \"title\": \"Codex-Managed-Agent: Open to Side\"\n      },\n      {\n        \"command\": \"codexAgent.maximizeDashboard\",\n        \"title\": \"Codex-Managed-Agent: Full Screen\"\n      },\n      {\n        \"command\": \"codexAgent.movePanelToNewWindow\",\n        \"title\": \"Codex-Managed-Agent: Move to New Window\"\n      },\n      {\n        \"command\": \"codexAgent.refreshPanel\",\n        \"title\": \"Codex-Managed-Agent: Refresh Panel\"\n      },\n      {\n        \"command\": \"codexAgent.startServer\",\n        \"title\": \"Codex-Managed-Agent: Start Local Server\"\n      }\n    ],\n    \"viewsContainers\": {\n      \"activitybar\": [\n        {\n          \"id\": \"codexManagedAgentSidebar\",\n          \"title\": \"Codex-Managed-Agent\",\n          \"icon\": \"media/codex-agent.svg\"\n        }\n      ],\n      \"panel\": [\n        {\n          \"id\": \"codexManagedAgentPanel\",\n          \"title\": \"Codex-Managed-Agent\",\n          \"icon\": \"media/codex-agent.svg\"\n        }\n      ]\n    },\n    \"views\": {\n      \"codexManagedAgentSidebar\": [\n        {\n          \"type\": \"webview\",\n          \"id\": \"codexAgent.sidebar\",\n          \"name\": \"Dashboard\"\n        }\n      ],\n      \"codexManagedAgentPanel\": [\n        {\n          \"type\": \"webview\",\n          \"id\": \"codexAgent.bottom\",\n          \"name\": \"Dashboard\"\n        }\n      ]\n    },\n    \"menus\": {\n      \"view/title\": [\n        {\n          \"command\": \"codexAgent.refreshPanel\",\n          \"when\": \"view == codexAgent.sidebar || view == codexAgent.bottom\",\n          \"group\": \"navigation\"\n        },\n        {\n          \"command\": \"codexAgent.openPanel\",\n          \"when\": \"view == codexAgent.sidebar || view == codexAgent.bottom\",\n          \"group\": \"navigation\"\n        },\n        {\n          \"command\": \"codexAgent.maximizeDashboard\",\n          \"when\": \"view == codexAgent.bottom\",\n          \"group\": \"navigation\"\n        }\n      ]\n    }\n  }\n}\n","exit_code":0,"status":"completed"}}
