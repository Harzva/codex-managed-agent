{"type":"item.completed","item":{"id":"item_1","type":"command_execution","command":"/bin/bash -lc \"nl -ba src/host/state-sync.js | sed -n '1,220p'\"","aggregated_output":"     1\tconst vscode = require(\"vscode\");\n     2\tconst fs = require(\"fs\");\n     3\tconst path = require(\"path\");\n     4\t\n     5\tconst {\n     6\t  getConfig,\n     7\t  summarizeServiceState,\n     8\t  fetchDashboardState,\n     9\t  fetchThreadDetail,\n    10\t  probeServer,\n    11\t  startServer,\n    12\t} = require(\"./server\");\n    13\tconst { readFileTail } = require(\"./auto-continue\");\n    14\t\n    15\tasync function ensureServer(panel, options = {}) {\n    16\t  const config = getConfig();\n    17\t  const probe = await probeServer(config.baseUrl);\n    18\t  if (probe.ok) {\n    19\t    return summarizeServiceState(true, {\n    20\t      baseUrl: config.baseUrl,\n    21\t      autoStarted: false,\n    22\t      message: \"Connected\",\n    23\t    });\n    24\t  }\n    25\t\n    26\t  if (!config.autoStartServer && !options.forceStart) {\n    27\t    return summarizeServiceState(false, {\n    28\t      baseUrl: config.baseUrl,\n    29\t      autoStarted: false,\n    30\t      message: probe.error || \"Server not reachable\",\n    31\t    });\n    32\t  }\n    33\t\n    34\t  const start = await startServer(panel.extensionUri);\n    35\t  if (!start.ok) {\n    36\t    return summarizeServiceState(false, {\n    37\t      baseUrl: config.baseUrl,\n    38\t      autoStarted: true,\n    39\t      message: start.error || \"Failed to start server\",\n    40\t      logPath: start.logPath,\n    41\t    });\n    42\t  }\n    43\t\n    44\t  return summarizeServiceState(true, {\n    45\t    baseUrl: config.baseUrl,\n    46\t    autoStarted: true,\n    47\t    message: \"Server started\",\n    48\t    logPath: start.logPath,\n    49\t  });\n    50\t}\n    51\t\n    52\tasync function openExternal(panel) {\n    53\t  const config = getConfig();\n    54\t  const target = await vscode.env.asExternalUri(vscode.Uri.parse(config.baseUrl));\n    55\t  await vscode.env.openExternal(target);\n    56\t}\n    57\t\n    58\tfunction isPidRunning(pid) {\n    59\t  if (!Number.isInteger(pid) || pid <= 0) return false;\n    60\t  try {\n    61\t    process.kill(pid, 0);\n    62\t    return true;\n    63\t  } catch {\n    64\t    return false;\n    65\t  }\n    66\t}\n    67\t\n    68\tfunction readJsonFile(filePath) {\n    69\t  try {\n    70\t    if (!fs.existsSync(filePath)) return null;\n    71\t    return JSON.parse(fs.readFileSync(filePath, \"utf8\"));\n    72\t  } catch {\n    73\t    return null;\n    74\t  }\n    75\t}\n    76\t\n    77\tfunction readTextFile(filePath) {\n    78\t  try {\n    79\t    if (!fs.existsSync(filePath)) return \"\";\n    80\t    return fs.readFileSync(filePath, \"utf8\").trim();\n    81\t  } catch {\n    82\t    return \"\";\n    83\t  }\n    84\t}\n    85\t\n    86\tfunction shortText(value, max = 120) {\n    87\t  const text = String(value || \"\").replace(/\\s+/g, \" \").trim();\n    88\t  if (!text) return \"\";\n    89\t  if (text.length <= max) return text;\n    90\t  return `${text.slice(0, Math.max(0, max - 1)).trimEnd()}…`;\n    91\t}\n    92\t\n    93\tfunction readCodexLoopDaemonState(panel) {\n    94\t  const stateDir = path.join(panel.extensionUri.fsPath, \".codex-loop\", \"state\");\n    95\t  if (!fs.existsSync(stateDir)) {\n    96\t    return {\n    97\t      available: false,\n    98\t      running: false,\n    99\t      label: \"Unavailable\",\n   100\t      detail: \"No local codex-loop state directory found.\",\n   101\t    };\n   102\t  }\n   103\t  const pidText = readTextFile(path.join(stateDir, \"daemon.pid\"));\n   104\t  const pid = Number.parseInt(pidText, 10);\n   105\t  const heartbeat = readJsonFile(path.join(stateDir, \"daemon_heartbeat.json\")) || {};\n   106\t  const launcherInfo = readJsonFile(path.join(stateDir, \"daemon_launcher.json\")) || {};\n   107\t  const status = readJsonFile(path.join(stateDir, \"status.json\")) || {};\n   108\t  const threadId = readTextFile(path.join(stateDir, \"thread_id.txt\")) || status.thread_id || \"\";\n   109\t  const running = isPidRunning(pid);\n   110\t  const interval = heartbeat.interval_minutes || heartbeat.intervalMinutes;\n   111\t  const launcher = launcherInfo.launcher || \"unknown\";\n   112\t  const heartbeatPhase = heartbeat.phase || status.phase || \"\";\n   113\t  const latestStatus = status.phase || \"\";\n   114\t  const exitedUnexpectedly = !running && Number.isInteger(pid) && pid > 0 && heartbeatPhase && heartbeatPhase !== \"stopped\";\n   115\t  const lastSummary = shortText(status.last_message_preview || \"\", 140);\n   116\t  const rawLogPath = shortText(status.raw_log_path || \"\", 120);\n   117\t  const tail = readFileTail(status.raw_log_path, 6000).trim();\n   118\t  const tailLine = shortText(\n   119\t    tail.split(/\\n/).map((line) => line.trim()).filter(Boolean).slice(-1)[0] || \"\",\n   120\t    180,\n   121\t  );\n   122\t  const metadataParts = [\n   123\t    threadId ? `Thread ${threadId.slice(0, 12)}` : \"\",\n   124\t    launcher ? `Launcher ${launcher}` : \"\",\n   125\t    exitedUnexpectedly ? \"Exited unexpectedly\" : \"\",\n   126\t    heartbeatPhase ? `${exitedUnexpectedly ? \"Last heartbeat\" : \"Heartbeat\"} ${heartbeatPhase}` : \"\",\n   127\t    interval ? `${interval} min interval` : \"\",\n   128\t    latestStatus ? `${exitedUnexpectedly ? \"Last status\" : \"Status\"} ${latestStatus}` : \"\",\n   129\t    rawLogPath ? `Log ${rawLogPath}` : \"\",\n   130\t    lastSummary ? `Last tick ${lastSummary}` : \"\",\n   131\t  ].filter(Boolean);\n   132\t  return {\n   133\t    available: true,\n   134\t    running,\n   135\t    pid: Number.isInteger(pid) ? pid : undefined,\n   136\t    threadId: threadId || undefined,\n   137\t    launcher,\n   138\t    heartbeatPhase: heartbeatPhase || undefined,\n   139\t    intervalMinutes: interval || undefined,\n   140\t    rawLogPath: status.raw_log_path || undefined,\n   141\t    tailLine: tailLine || undefined,\n   142\t    label: running ? \"Running\" : (exitedUnexpectedly ? \"Exited\" : \"Stopped\"),\n   143\t    detail: metadataParts.length\n   144\t      ? metadataParts.join(\" · \")\n   145\t      : (running\n   146\t        ? (interval ? `Heartbeat active · ${interval} min interval` : \"Heartbeat active\")\n   147\t        : (exitedUnexpectedly ? \"Exited unexpectedly\" : (status.phase ? `Last status: ${status.phase}` : \"No active daemon heartbeat\"))),\n   148\t  };\n   149\t}\n   150\t\n   151\tfunction postMessage(panel, payload) {\n   152\t  if (panel.panel) panel.panel.webview.postMessage(payload);\n   153\t  if (panel.sidebarView) panel.sidebarView.webview.postMessage(payload);\n   154\t  if (panel.bottomView) panel.bottomView.webview.postMessage(payload);\n   155\t}\n   156\t\n   157\tfunction broadcastState(panel, payload) {\n   158\t  const codexLinkState = panel.getCodexLinkState();\n   159\t  const enrichedPayload = {\n   160\t    ...payload,\n   161\t    codexLinkState,\n   162\t  };\n   163\t  panel.lastPayload = enrichedPayload;\n   164\t  if (panel.panel) {\n   165\t    panel.panel.webview.postMessage({\n   166\t      ...enrichedPayload,\n   167\t      currentSurface: panel.editorSurface,\n   168\t    });\n   169\t  }\n   170\t  if (panel.sidebarView) {\n   171\t    panel.sidebarView.webview.postMessage({\n   172\t      ...enrichedPayload,\n   173\t      currentSurface: \"left\",\n   174\t    });\n   175\t  }\n   176\t  if (panel.bottomView) {\n   177\t    panel.bottomView.webview.postMessage({\n   178\t      ...enrichedPayload,\n   179\t      currentSurface: \"bottom\",\n   180\t    });\n   181\t  }\n   182\t}\n   183\t\n   184\tfunction broadcastLinkState(panel) {\n   185\t  if (!panel.hasSurface() || !panel.lastPayload) return;\n   186\t  const codexLinkState = panel.getCodexLinkState();\n   187\t  panel.lastPayload = {\n   188\t    ...panel.lastPayload,\n   189\t    codexLinkState,\n   190\t  };\n   191\t  postMessage(panel, {\n   192\t    type: \"codexLinkStatePatched\",\n   193\t    codexLinkState,\n   194\t  });\n   195\t}\n   196\t\n   197\tfunction promptQueueConfirmed(entry, thread, effectiveRunningIds, detailThread) {\n   198\t  if (!entry) return false;\n   199\t  if (effectiveRunningIds.has(entry.threadId)) return true;\n   200\t  const queuedAtMs = Date.parse(entry.queuedAt || \"\");\n   201\t  if (!Number.isFinite(queuedAtMs)) return false;\n   202\t  const candidates = [thread, detailThread];\n   203\t  return candidates.some((item) => {\n   204\t    if (!item) return false;\n   205\t    const updatedAtMs = Date.parse(item.updated_at_iso || item.updatedAt || \"\");\n   206\t    if (Number.isFinite(updatedAtMs) && updatedAtMs >= queuedAtMs - 1000) {\n   207\t      return true;\n   208\t    }\n   209\t    const previewLogs = Array.isArray(item.preview_logs) ? item.preview_logs : [];\n   210\t    return previewLogs.some((log) => {\n   211\t      const logTsMs = Date.parse(log.ts_iso || \"\");\n   212\t      return Number.isFinite(logTsMs) && logTsMs >= queuedAtMs - 1000;\n   213\t    });\n   214\t  });\n   215\t}\n   216\t\n   217\tfunction reconcileOptimisticQueuedPrompts(panel, dashboard, effectiveRunningIds, detail) {\n   218\t  const pending = panel.optimisticQueuedPrompts || {};\n   219\t  const threads = Array.isArray(dashboard?.threads) ? dashboard.threads : [];\n   220\t  const next = {};\n","exit_code":0,"status":"completed"}}
