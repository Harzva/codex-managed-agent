{"type":"item.completed","item":{"id":"item_5","type":"command_execution","command":"/bin/bash -lc \"nl -ba src/host/state-sync.js | sed -n '86,160p'\"","aggregated_output":"    86\tfunction shortText(value, max = 120) {\n    87\t  const text = String(value || \"\").replace(/\\s+/g, \" \").trim();\n    88\t  if (!text) return \"\";\n    89\t  if (text.length <= max) return text;\n    90\t  return `${text.slice(0, Math.max(0, max - 1)).trimEnd()}…`;\n    91\t}\n    92\t\n    93\tfunction normalizeWorkspacePath(value) {\n    94\t  const raw = String(value || \"\").trim();\n    95\t  if (!raw) return \"\";\n    96\t  const normalized = raw.replace(/\\\\/g, \"/\").replace(/\\/+$/, \"\");\n    97\t  return normalized || raw;\n    98\t}\n    99\t\n   100\tfunction deriveRootIdentity(cwd) {\n   101\t  const rootKey = normalizeWorkspacePath(cwd);\n   102\t  if (!rootKey) {\n   103\t    return {\n   104\t      rootKey: undefined,\n   105\t      rootLabel: undefined,\n   106\t    };\n   107\t  }\n   108\t  const parts = rootKey.split(\"/\").filter(Boolean);\n   109\t  return {\n   110\t    rootKey,\n   111\t    rootLabel: parts[parts.length - 1] || rootKey,\n   112\t  };\n   113\t}\n   114\t\n   115\tfunction enrichThreadRootIdentity(thread) {\n   116\t  if (!thread || typeof thread !== \"object\") return thread;\n   117\t  const cwd = normalizeWorkspacePath(thread.cwd);\n   118\t  const identity = deriveRootIdentity(cwd);\n   119\t  return {\n   120\t    ...thread,\n   121\t    cwd: cwd || thread.cwd,\n   122\t    rootKey: identity.rootKey,\n   123\t    rootLabel: identity.rootLabel,\n   124\t  };\n   125\t}\n   126\t\n   127\tfunction enrichDashboardRootIdentity(dashboard) {\n   128\t  const nextDashboard = dashboard && typeof dashboard === \"object\" ? dashboard : {};\n   129\t  return {\n   130\t    ...nextDashboard,\n   131\t    threads: Array.isArray(nextDashboard.threads) ? nextDashboard.threads.map(enrichThreadRootIdentity) : [],\n   132\t    runningThreads: Array.isArray(nextDashboard.runningThreads) ? nextDashboard.runningThreads.map(enrichThreadRootIdentity) : [],\n   133\t  };\n   134\t}\n   135\t\n   136\tfunction enrichDetailRootIdentity(detail) {\n   137\t  if (!detail || typeof detail !== \"object\") return detail;\n   138\t  return detail.thread\n   139\t    ? {\n   140\t        ...detail,\n   141\t        thread: enrichThreadRootIdentity(detail.thread),\n   142\t      }\n   143\t    : detail;\n   144\t}\n   145\t\n   146\tfunction readCodexLoopDaemonState(panel) {\n   147\t  const stateDir = path.join(panel.extensionUri.fsPath, \".codex-loop\", \"state\");\n   148\t  if (!fs.existsSync(stateDir)) {\n   149\t    return {\n   150\t      available: false,\n   151\t      running: false,\n   152\t      label: \"Unavailable\",\n   153\t      detail: \"No local codex-loop state directory found.\",\n   154\t    };\n   155\t  }\n   156\t  const pidText = readTextFile(path.join(stateDir, \"daemon.pid\"));\n   157\t  const pid = Number.parseInt(pidText, 10);\n   158\t  const heartbeat = readJsonFile(path.join(stateDir, \"daemon_heartbeat.json\")) || {};\n   159\t  const launcherInfo = readJsonFile(path.join(stateDir, \"daemon_launcher.json\")) || {};\n   160\t  const status = readJsonFile(path.join(stateDir, \"status.json\")) || {};\n","exit_code":0,"status":"completed"}}
