hboard = enrichDashboardRootIdentity(rawDashboard);\n   327\t    const loopDaemon = readCodexLoopDaemonState(panel);\n   328\t    const codexLinkState = panel.getCodexLinkState();\n   329\t    const currentThreads = Array.isArray(dashboard.threads) ? dashboard.threads : [];\n   330\t    const effectiveRunningThreads = (dashboard.runningThreads || []).filter((thread) =>\n   331\t      panel.isEffectivelyRunningThread(thread, codexLinkState),\n   332\t    );\n   333\t    const nextRunningIds = new Set(effectiveRunningThreads.map((thread) => thread.id));\n   334\t    const completedEvents = [...panel.previousRunningIds]\n   335\t      .filter((threadId) => !nextRunningIds.has(threadId))\n   336\t      .map((threadId) => {\n   337\t        const thread = currentThreads.find((item) => item.id === threadId) || {};\n   338\t        return {\n   339\t          id: `${threadId}:${Date.now()}`,\n   340\t          threadId,\n   341\t          title: thread.title || threadId,\n   342\t          status: thread.status || \"completed\",\n   343\t          updatedAt: thread.updated_at_iso || \"\",\n   344\t        };\n   345\t      });\n   346\t    for (const item of completedEvents) {\n   347\t      const loopConfig = panel.autoContinueConfigs[item.threadId];\n   348\t      if (loopConfig && loopConfig.active && loopConfig.remaining > 0) {\n   349\t        await panel.triggerAutoContinue(item.threadId, loopConfig);\n   350\t      }\n   351\t    }\n   352\t    if (completedEvents.length) {\n   353\t      panel.recentCompletions = [...completedEvents, ...panel.recentCompletions].slice(0, 8);\n   354\t      const label = completedEvents.length === 1\n   355\t        ? completedEvents[0].title\n   356\t        : `${completedEvents.length} threads`;\n   357\t      vscode.window.showInformationMessage(`Codex-Managed-Agent: completed ${label}`);\n   358\t    }\n   359\t    panel.previousRunningIds = nextRunningIds;\n   360\t    if (!panel.selectedThreadId && dashboard.threads.length) {\n   361\t      panel.selectedThreadId = dashboard.threads[0].id;\n   362\t    }\n   363\t    const hasSelected = dashboard.threads.some((thread) => thread.id === panel.selectedThreadId);\n   364\t    if (!hasSelected) {\n   365\t      panel.selectedThreadId = dashboard.threads[0]?.id;\n   366\t    }\n","exit_code":0,"status":"completed"}}
