n        ].join(\"\");\n        document.getElementById(\"usageSummary\").innerHTML = insights ? [\n          renderSummaryCard(\n            \"Usage Persona\",\n            ((insights.guidance && insights.guidance.usage_persona) || [\"均衡型\"]).join(\" · \"),\n            \"基于历史输入的工作风格归纳，更偏使用画像，不做武断的人格结论。\",\n            \"Planning\",\n","exit_code":0,"status":"completed"}}
