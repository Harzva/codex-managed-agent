ent_window + \" / \" + String(report.current_inputs || 0) + \" inputs\",\n  3764\t            ((report.previous_persona || [\"基线不足\"]).join(\" · \")) + \" · \" + report.previous_window\n  3765\t          ),\n  3766\t          renderInsightCard(\"Next action\", nextAction, \"Weekly\"),\n  3767\t          highlights.map((line, index) => renderInsightCard(\"Shift \" + (index + 1), line, \"Delta\")).join(\"\"),\n  3768\t          shifts.length ? '<div class=\"shift-chip-row\">' + shifts.slice(0, 5).map((item) => {\n","exit_code":0,"status":"completed"}}
