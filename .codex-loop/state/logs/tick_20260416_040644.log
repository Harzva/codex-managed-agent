to.randomBytes(4).toString(\"hex\")}`;\n    47\t}\n    48\t\n    49\tconst TASK_STATES = Object.freeze({\n    50\t  QUEUED: \"queued\",\n    51\t  ASSIGNED: \"assigned\",\n    52\t  RUNNING: \"running\",\n    53\t  BLOCKED: \"blocked\",\n    54\t  REVIEW: \"review\",\n    55\t  COMPLETED: \"completed\",\n    56\t  FAILED: \"failed\",\n    57\t  STALE: \"stale\",\n    58\t});\n    59\t\n    60\tconst THREAD_ACTIVE_TASK_STATES = new Set([\n    61\t  TASK_STATES.RUNNING,\n    62\t  TASK_STATES.ASSIGNED,\n    63\t  TASK_STATES.BLOCKED,\n    64\t  TASK_STATES.REVIEW,\n    65\t]);\n    66\t\n    67\tconst CLAIMABLE_TASK_STATES = new Set([\n    68\t  TASK_STATES.ASSIGNED,\n    69\t  TASK_STATES.QUEUED,\n    70\t  TASK_STATES.STALE,\n    71\t]);\n    72\t\n    73\tconst BLOCKABLE_TASK_STATES = new Set([\n    74\t  TASK_STATES.RUNNING,\n    75\t  TASK_STATES.ASSIGNED,\n    76\t]);\n    77\t\n    78\tconst COMPLETABLE_TASK_STATES = new Set([\n    79\t  TASK_STATES.RUNNING,\n    80\t  TASK_STATES.ASSIGNED,\n    81\t  TASK_STATES.REVIEW,\n    82\t]);\n    83\t\n    84\tfunction taskStatus(task, fallback = TASK_STATES.QUEUED) {\n    85\t  return String((task && task.status) || fallback);\n    86\t}\n    87\t\n    88\tfunction taskHasStatus(task, states) {\n    89\t  return states.has(taskStatus(task, \"\"));\n    90\t}\n    91\t\n    92\tfunction promptForWorkspace(panel) {\n    93\t  const selectedThread = panel.lastPayload\n    94\t    && panel.lastPayload.dashboard\n    95\t    && Array.isArray(panel.lastPayload.dashboard.threads)\n    96\t    ? panel.lastPayload.dashboard.threads.find((thread) => thread && thread.id === panel.selectedThreadId)\n    97\t    : undefined;\n    98\t  if (selectedThread && selectedThread.cwd && fs.existsSync(selectedThread.cwd)) {\n    99\t    return normalizePath(selectedThread.cwd);\n   100\t  }\n   101\t  const firstFolder = vscode.workspace.workspaceFolders && vscode.workspace.workspaceFolders[0];\n   102\t  if (firstFolder && firstFolder.uri